{
  "mcpServers": {
    "datadog": {
       "type": "http",
       "url": "https://mcp.datadoghq.com/v1/mcp",
       "headers": {
          "DD_API_KEY": "{DD_API_KEY}",
          "DD_APPLICATION_KEY": "{DD_APPLICATION_KEY}"
       }
     },
    "server-name": {
      "env": {
        "API_KEY": "{API_KEY}",
        "DEBUG": "true",
        "TIMEOUT": "30000"
      }
    }
  }
}